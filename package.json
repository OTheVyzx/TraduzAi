{
  "name": "traduzai",
  "private": true,
  "version": "0.1.0",
  "description": "TraduzAi — Tradutor desktop de mangá/manhwa/manhua por IA",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-vite.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:frontend": "npm run build",
    "test:pipeline": "cd pipeline && .\\venv\\Scripts\\python.exe -m pytest",
    "qa:quick": "npm run build && cd pipeline && .\\venv\\Scripts\\python.exe -m pytest -m \"not slow\"",
    "qa:e2e": "npm run build && playwright test",
    "qa:all": "npm run build && cd pipeline && .\\venv\\Scripts\\python.exe -m pytest && cd .. && playwright test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "build": "tsc && node scripts/run-vite.mjs build",
    "preview": "node scripts/run-vite.mjs preview",
    "tauri": "node scripts/run-tauri.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "ag-psd": "^30.1.1",
    "canvas": "^3.2.3",
    "konva": "^10.2.5",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
