TRADUZAI_ENV=dev
TRADUZAI_BIND=local
TRADUZAI_PORT=8787
TRADUZAI_DATABASE_URL=sqlite:///D:/TraduzAi/data/saas/app.db
TRADUZAI_STORAGE_DIR=D:/TraduzAi/data/saas/storage
TRADUZAI_CORS_ORIGINS=http://127.0.0.1:5174

TRADUZAI_ADMIN_EMAIL=admin@local
TRADUZAI_ADMIN_PASSWORD=
TRADUZAI_GOOGLE_CLIENT_ID=
TRADUZAI_GOOGLE_CLIENT_SECRET=

TRADUZAI_WORKER_TOKEN=

TRADUZAI_LEASE_TIMEOUT_SECONDS=180
TRADUZAI_HEARTBEAT_INTERVAL_SECONDS=20

TRADUZAI_PROJECT_ROOT=D:/TraduzAi
TRADUZAI_PIPELINE_MAIN=D:/TraduzAi/pipeline/main.py
TRADUZAI_PIPELINE_PYTHON=D:/TraduzAi/pipeline/venv/Scripts/python.exe
TRADUZAI_WORKER_NAME=admin-pc
TRADUZAI_WORKER_WORK_DIR=D:/TraduzAi/data/worker
TRADUZAI_API_URL=http://127.0.0.1:8787
# Default: 1. Set to 0 to force the legacy one-process-per-job runner.
TRADUZAI_FAST_PAGE_SERVER=1

TRADUZAI_MAX_FILE_MB=80
TRADUZAI_MAX_JOB_MB=1000
TRADUZAI_MAX_FILES_PER_JOB=300
TRADUZAI_MAX_ZIP_EXPANDED_MB=1500
